{
  "expo": {
    "name": "MazdoorPing Employer",
    "slug": "mazdoorping-employer",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#3B82F6"
    },
    "scheme": "mazdoorpingemployer",
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "MazdoorPing needs access to your photos to upload your profile picture."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "MazdoorPing needs your location to find nearby workers."
        }
      ]
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mazdoorping.employer",
      "buildNumber": "1"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#3B82F6"
      },
      "package": "com.mazdoorping.employer",
      "versionCode": 1,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "supabaseUrl": "",
      "supabaseAnonKey": ""
    }
  }
}
